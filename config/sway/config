### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4

# All hail  vim
set $left h
set $down j
set $up k
set $right l

# Alacritty is best terminal
set $term alacritty

# Rofi has a better config than Wofi dont @ me
set $menu rofi -show drun

### Output configuration
#
# If this doesnt work for you, hardcode it, gamer
# I cannot for the life of me get this to work with $XDG_CONFIG_HOME and I am giving up
# You're welcome to try and make an issue
output * bg "$HOME/.config/Backgrounds/H4rdH4ck3r_BG.jpg" fill

# Delicious pixel
default_border pixel 1

# Colors: border background text indicator child_border (if you want color change use child border)
# `man 5 sway` for documentation. its down in there :)
client.focused          #e965a5 #282433 #eee9fc #b1f2a7 #e965af
client.unfocused        #b1baf4 #282433 #eee9fc #3f3951 #b1baf4
client.focused_inactive #e965a5 #282433 #eee9fc #b3f4f3 #b3f4f3
client.urgent           #ebde76 #282433 #282433 #ebde76 #e192ef

# Gap time
gaps inner 5

# This is a swayfx configuration to give rounded corners (don't use without swayfx)
 corner_radius 3

# font config (you may have to mess with this low key) cozette is rough as a vector font
font pango:cozettecrossedseven regular 12

# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

### Idle configuration
# plz lock ur screen
 exec swayidle -w \
          timeout 300 'swaylock -f -c 000000' \
          timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
          before-sleep 'swaylock -f -c 000000'

# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

### Input configuration
   input type:touchpad {
       dwt enabled
       tap enabled
       natural_scroll enabled
       middle_emulation enabled
       }
# You can also configure each device individually.
